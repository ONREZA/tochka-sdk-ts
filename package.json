{
	"name": "tochka-sdk-ts",
	"private": true,
	"type": "module",
	"workspaces": ["packages/*"],
	"scripts": {
		"build": "bun --filter='@onreza/*' run build",
		"test": "bun --filter='@onreza/*' run test",
		"typecheck": "bun --filter='@onreza/*' run typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"gen": "bun tools/gen.ts",
		"spec:fetch": "bun tools/fetch-spec.ts",
		"spec:diff": "bun tools/diff.ts",
		"spec:sync": "bun tools/sync.ts",
		"prepare": "lefthook install || echo 'Install lefthook: https://github.com/evilmartians/lefthook'",
		"release": "onreza-release"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "latest",
		"lefthook": "^2.1.4",
		"onreza-release": "^2.7.0",
		"openapi-typescript": "^7.4.4",
		"typescript": "^5.6.3"
	},
	"engines": {
		"node": ">=18"
	}
}
