# Smoke-тесты против Точка Банка API.
# Скопируй этот файл в .env (он в .gitignore) и заполни значения.
# Запуск: TOCHKA_SMOKE=1 bun test test/sandbox

# ── Гейт ──────────────────────────────────────────────────────────────────
# Без этого флага smoke-тесты пропускаются (skip).
TOCHKA_SMOKE=1

# Режим авторизации: sandbox | jwt
#   sandbox — литеральный `Bearer sandbox.jwt.token`, ничего не требует.
#   jwt     — персональный JWT-ключ из ЛК Точки (prod-окружение, осторожно!).
TOCHKA_MODE=sandbox

# ── JWT mode ──────────────────────────────────────────────────────────────
# Нужно только при TOCHKA_MODE=jwt.
# Получается в ЛК: Настройки → Интеграции → API → Создать ключ.
TOCHKA_JWT=

# ── Customer code ─────────────────────────────────────────────────────────
# Код клиента (компании) в Точке. Нужен почти для всех endpoint'ов.
# В sandbox-режиме можно оставить пустым — customers.list() вернёт тестовых.
TOCHKA_CUSTOMER_CODE=

# ── Override base URL (опционально) ──────────────────────────────────────
# Если не задан — берётся sandbox URL для TOCHKA_MODE=sandbox, prod для jwt.
# TOCHKA_BASE_URL=https://enter.tochka.com/sandbox/v2/

# ── Pay Gateway (опционально) ────────────────────────────────────────────
# Отдельный продукт, включать когда будем тестировать приём карт.
# TOCHKA_PG_JWT=
# TOCHKA_PG_PRIVATE_KEY_PATH=./pay-gateway-private.pkcs8.pem
